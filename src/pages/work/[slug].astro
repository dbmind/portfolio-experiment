---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Base title={`${project.data.title} — ${project.data.subtitle}`} description={project.data.description}>
  <Nav activeSection="work" />

  <main class="pt-40 pb-24 max-md:pt-28">

    <!-- Narrow header section -->
    <header class="px-12 max-md:px-6">
      <div class="max-w-[760px] mx-auto">

        <!-- Back link -->
        <a
          href="/"
          class="reveal inline-flex items-center gap-2 no-underline text-[var(--color-text)]/50 hover:text-[var(--color-text)]/80 transition-colors duration-300 mb-16"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M13 8H3M7 4l-4 4 4 4" stroke="currentColor" stroke-width="1.2" />
          </svg>
          <span class="text-[11px] uppercase tracking-[0.15em]" style="font-family: var(--font-mono);">Back to work</span>
        </a>

        <!-- Project header -->
        <div class="reveal" style="transition-delay: 0.1s;">
          <h1
            class="font-normal tracking-[-0.03em] leading-[1.03] text-[var(--color-text)] mb-3"
            style="font-family: var(--font-headline); font-size: clamp(44px, 7vw, 80px);"
          >{project.data.title}</h1>

          <h2
            class="text-[20px] font-normal text-[var(--color-text)]/55 mb-10"
            style="font-family: var(--font-body);"
          >{project.data.subtitle}</h2>

          <div class="flex gap-2 flex-wrap">
            {project.data.tags.map((tag: string) => (
              <span
                class="text-[10px] uppercase tracking-[0.1em] text-[var(--color-text)]/45 px-2.5 py-1.5 border border-[var(--color-text)]/12 rounded-sm"
                style="font-family: var(--font-mono);"
              >{tag}</span>
            ))}
          </div>
        </div>

      </div>
    </header>

    <!-- Wide content area — text centers itself, images go full width -->
    <div class="reveal project-content mt-16 px-8 max-md:px-5" style="transition-delay: 0.2s;">
      <Content />
    </div>

    <!-- Footer nav -->
    <div class="px-12 max-md:px-6 mt-24">
      <div class="max-w-[760px] mx-auto pt-12 border-t border-[var(--color-text)]/5 flex justify-between items-center">
        <a
          href="/"
          class="inline-flex items-center gap-2 no-underline text-[var(--color-text)]/50 hover:text-[var(--color-accent)] transition-colors duration-300"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M13 8H3M7 4l-4 4 4 4" stroke="currentColor" stroke-width="1.2" />
          </svg>
          <span class="text-[11px] uppercase tracking-[0.15em]" style="font-family: var(--font-mono);">All projects</span>
        </a>
      </div>
    </div>

  </main>

  <Footer />
</Base>

<style>
  /* ── Body text ──────────────────────────────────────────────── */
  .project-content :global(p) {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.9;
    color: rgba(240, 237, 230, 0.55);
    margin: 0 auto 1.6em;
    max-width: 660px;
  }

  /* Lead paragraph — the opening statement */
  .project-content :global(p.lead) {
    font-size: 22px;
    line-height: 1.75;
    color: rgba(240, 237, 230, 0.70);
    max-width: 720px;
    margin-bottom: 2.5em;
  }

  .project-content :global(strong) {
    color: rgba(240, 237, 230, 0.80);
    font-weight: 500;
  }

  /* ── Section headings ───────────────────────────────────────── */
  .project-content :global(h2) {
    font-family: var(--font-headline);
    font-size: clamp(34px, 4.5vw, 54px);
    font-weight: 400;
    color: rgba(240, 237, 230, 0.92);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 4.5em auto 0.9em;
    max-width: 760px;
    padding-top: 1.2em;
    border-top: 1px solid rgba(240, 237, 230, 0.07);
  }

  /* Section label — mono marker with accent line */
  .project-content :global(h3) {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    color: rgba(240, 237, 230, 0.50);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin: 3.5em auto 1em;
    max-width: 660px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .project-content :global(h3)::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  /* ── Pull quote / blockquote ────────────────────────────────── */
  .project-content :global(blockquote) {
    font-family: var(--font-headline);
    font-style: italic;
    font-size: clamp(24px, 3.5vw, 40px);
    line-height: 1.4;
    color: rgba(240, 237, 230, 0.85);
    letter-spacing: -0.025em;
    border: none;
    margin: 4em auto;
    max-width: 820px;
    padding: 0;
    position: relative;
  }

  .project-content :global(blockquote)::before {
    content: '';
    display: block;
    width: 36px;
    height: 2px;
    background: var(--color-accent);
    margin-bottom: 1.4em;
  }

  .project-content :global(blockquote p) {
    font-size: inherit;
    line-height: inherit;
    color: inherit;
    max-width: none;
    margin: 0;
  }

  /* ── Images — full width, break out of text column ─────────── */
  .project-content :global(figure.img-figure) {
    display: block;
    margin: 5rem 0;
    width: 100%;
  }

  .project-content :global(figure.img-figure img) {
    width: 100%;
    display: block;
    border-radius: 3px;
    filter: brightness(0.88);
    transition: filter 0.4s ease-out;
  }

  .project-content :global(figure.img-figure:hover img) {
    filter: brightness(1.0);
  }

  /* Caption — sits below image with an accent dash */
  .project-content :global(figcaption.img-caption) {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 16px;
    padding-left: 2px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: rgba(240, 237, 230, 0.60);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    line-height: 1.5;
    transition: color 250ms ease-out;
  }

  .project-content :global(figcaption.img-caption)::before {
    content: '';
    display: inline-block;
    width: 18px;
    height: 1px;
    background: rgba(240, 237, 230, 0.25);
    flex-shrink: 0;
    transition: width 250ms ease-out, background 250ms ease-out;
  }

  /* ASCII flavour — trailing // appears on figure hover */
  .project-content :global(figcaption.img-caption)::after {
    content: ' //';
    color: var(--color-accent);
    opacity: 0;
    transition: opacity 250ms ease-out;
  }

  .project-content :global(figure.img-figure:hover figcaption.img-caption) {
    color: rgba(240, 237, 230, 0.85);
  }

  .project-content :global(figure.img-figure:hover figcaption.img-caption)::before {
    width: 28px;
    background: var(--color-accent);
  }

  .project-content :global(figure.img-figure:hover figcaption.img-caption)::after {
    opacity: 1;
  }

  /* ── ↑ annotation lines ──────────────────────────────────────── */
  .project-content :global(p.annotation) {
    font-family: var(--font-mono);
    font-size: 11px !important;
    color: rgba(240, 237, 230, 0.40) !important;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    line-height: 1.5;
    margin-top: -2.5em;
    margin-bottom: 3em;
    max-width: none;
    padding-left: 2px;
  }
</style>

<script>
  // ── Lead paragraph
  const content = document.querySelector('.project-content');
  if (content) {
    const firstPara = content.querySelector('p');
    if (firstPara && !firstPara.querySelector('img')) {
      firstPara.classList.add('lead');
    }
  }

  // ── Convert image paragraphs → <figure> elements for full-bleed layout
  let imgIndex = 0;
  document.querySelectorAll('.project-content p').forEach((p) => {
    const img = p.querySelector('img');
    if (img && p.children.length === 1) {
      const alt = img.getAttribute('alt') || '';

      // First two images load eagerly at high priority; rest lazy
      img.setAttribute('decoding', 'async');
      if (imgIndex < 2) {
        img.setAttribute('loading', 'eager');
        img.setAttribute('fetchpriority', 'high');
      } else {
        img.setAttribute('loading', 'lazy');
      }
      imgIndex++;

      const figure = document.createElement('figure');
      figure.className = 'img-figure reveal-slow';

      // Move img into figure (DOM move, not clone)
      figure.appendChild(img);

      if (alt) {
        const cap = document.createElement('figcaption');
        cap.className = 'img-caption';
        cap.textContent = alt;
        figure.appendChild(cap);
      }

      p.parentNode!.insertBefore(figure, p);
      p.remove();
    }
  });

  // ── Style ↑ annotation paragraphs as captions
  document.querySelectorAll('.project-content p').forEach((p) => {
    if (p.textContent?.trimStart().startsWith('↑')) {
      p.classList.add('annotation');
    }
  });

  // ── Scroll reveal observer for figures
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    },
    { threshold: 0.05 }
  );

  document.querySelectorAll('.project-content .reveal-slow').forEach((el) => {
    observer.observe(el);
  });
</script>
