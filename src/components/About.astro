---
const stats = [
  { label: 'Experience', value: '15+' },
  { label: 'Markets', value: '15+' },
  { label: 'BJJ', value: 'Brown' },
];

const services = [
  'Digital Design',
  'Branding Identity',
  'Art Direction',
  'Design Systems',
  'AI Consultancy',
  'Photo Retouching',
];
---

<section class="py-[120px] px-12 max-md:px-6 max-md:py-16 border-t border-[var(--color-text)]/5">
  <div class="reveal-slow grid grid-cols-[1fr_1.5fr] gap-20 max-w-[1100px] mx-auto max-md:grid-cols-1 max-md:gap-12">
    <!-- Left: Label + placeholder portrait -->
    <div>
      <div
        class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-text)]/50 mb-6"
        style="font-family: var(--font-mono);"
      >About</div>
      <div class="w-full aspect-[3/4] rounded-md border border-[var(--color-text)]/5 flex items-center justify-center overflow-hidden"
        style="background: linear-gradient(135deg, rgba(240,237,230,0.05), rgba(240,237,230,0.02));"
      >
        <span
          class="text-[80px] text-[var(--color-text)]/5"
          style="font-family: var(--font-display); font-style: italic;"
        >DB</span>
      </div>
    </div>

    <!-- Right: Bio content -->
    <div class="flex flex-col justify-center">
      <h2
        class="font-normal tracking-[-0.02em] leading-[1.15] text-[var(--color-text)] mb-7"
        style="font-family: var(--font-headline); font-size: clamp(32px, 4vw, 48px);"
      >
        Braz<span class="accent-char">i</span>lian-It<span class="accent-char">a</span>lian designer,<br />
        <span class="text-[var(--color-text)]/40">based in London.</span>
      </h2>

      <p
        class="text-[17px] leading-[1.8] text-[var(--color-text)]/60 mb-4 max-w-[520px]"
        style="font-family: var(--font-body);"
      >
        I care about clarity, craft, and helping teams move faster
        without losing soul. I've built design systems, led rebrands,
        mentored juniors, and worked closely with stakeholders to bring
        ideas to life with purpose and precision.
      </p>
      <p
        class="text-[17px] leading-[1.8] text-[var(--color-text)]/50 mb-10 max-w-[520px]"
        style="font-family: var(--font-body);"
      >
        Outside of work, I co-run a Jiu-Jitsu gym, drink way too much
        coffee, and enjoy making good brands look even better.
      </p>

      <!-- Stats -->
      <div class="flex gap-14 max-md:gap-8">
        {stats.map((stat) => (
          <div>
            <div
              class="text-[32px] tracking-[-0.02em] text-[var(--color-accent)]"
              style="font-family: var(--font-display); font-style: italic;"
            >{stat.value}</div>
            <div
              class="text-[9px] uppercase tracking-[0.15em] text-[var(--color-text)]/45 mt-1"
              style="font-family: var(--font-mono);"
            >{stat.label}</div>
          </div>
        ))}
      </div>

      <!-- Services -->
      <div class="mt-12 pt-7 border-t border-[var(--color-text)]/6">
        <div
          class="text-[10px] uppercase tracking-[0.15em] text-[var(--color-text)]/50 mb-4"
          style="font-family: var(--font-mono);"
        >Services</div>
        <div class="flex gap-3 flex-wrap">
          {services.map((s) => (
            <span
              class="text-[14px] text-[var(--color-text)]/60 px-4 py-2 border border-[var(--color-text)]/12 rounded-full"
              style="font-family: var(--font-body);"
            >{s}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
